---
---
<section id="academics" class="py-24 bg-surface-container-highest">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    
    <div class="text-center mb-16">
      <span class="font-label-md text-label-md text-secondary uppercase tracking-[0.2em]" data-i18n="curriculum.roadmap">Academic Roadmap</span>
      <h2 class="font-headline-md text-headline-md text-primary mt-2" data-i18n="curriculum.title">Stages of Mastery</h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border border-outline/20">
      
      <!-- Level 1: Muqaddimat -->
      <div class="bg-white p-12 border-b md:border-b-0 md:border-r border-outline/10">
        <div class="text-secondary font-headline-sm text-headline-sm mb-6" data-i18n="curriculum.lvl1.title">01. Muqaddimat</div>
        <h4 class="font-label-md text-label-md text-on-surface mb-4" data-i18n="curriculum.lvl1.sub">THE FOUNDATION</h4>
        <ul class="space-y-4 font-body-md text-body-md text-on-surface-variant">
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary flex-shrink-0"></span><span data-i18n="curriculum.lvl1.i1">Arabic Grammar (Sarf/Nahw)</span></li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary flex-shrink-0"></span><span data-i18n="curriculum.lvl1.i2">Formal Logic (Mantiq)</span></li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary flex-shrink-0"></span><span data-i18n="curriculum.lvl1.i3">Introductory Jurisprudence</span></li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary flex-shrink-0"></span><span data-i18n="curriculum.lvl1.i4">Quranic Sciences</span></li>
        </ul>
      </div>
      
      <!-- Level 2: Sutuh -->
      <div class="bg-white p-12 border-b md:border-b-0 md:border-r border-outline/10 relative">
        <div class="absolute top-0 right-0 p-4">
          <span class="material-symbols-outlined text-secondary opacity-20 text-6xl">school</span>
        </div>
        <div class="text-secondary font-headline-sm text-headline-sm mb-6" data-i18n="curriculum.lvl2.title">02. Sutuh</div>
        <h4 class="font-label-md text-label-md text-on-surface mb-4" data-i18n="curriculum.lvl2.sub">THE STRUCTURE</h4>
        <ul class="space-y-4 font-body-md text-body-md text-on-surface-variant">
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary flex-shrink-0"></span><span data-i18n="curriculum.lvl2.i1">Principles of Law (Usul)</span></li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary flex-shrink-0"></span><span data-i18n="curriculum.lvl2.i2">Comparative Philosophy</span></li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary flex-shrink-0"></span><span data-i18n="curriculum.lvl2.i3">Theology (Kalam)</span></li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary flex-shrink-0"></span><span data-i18n="curriculum.lvl2.i4">Advanced Rhetoric</span></li>
        </ul>
      </div>
      
      <!-- Level 3: Kharij -->
      <div class="bg-primary p-12 text-white">
        <div class="text-secondary-fixed font-headline-sm text-headline-sm mb-6" data-i18n="curriculum.lvl3.title">03. Kharij</div>
        <h4 class="font-label-md text-label-md text-white/70 mb-4" data-i18n="curriculum.lvl3.sub">THE INDEPENDENT RESEARCH</h4>
        <ul class="space-y-4 font-body-md text-body-md text-white/90">
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary-fixed flex-shrink-0"></span><span data-i18n="curriculum.lvl3.i1">Ijtihad Foundations</span></li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary-fixed flex-shrink-0"></span><span data-i18n="curriculum.lvl3.i2">Expert Seminars</span></li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary-fixed flex-shrink-0"></span><span data-i18n="curriculum.lvl3.i3">Original Research</span></li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary-fixed flex-shrink-0"></span><span data-i18n="curriculum.lvl3.i4">Advanced Metaphysics</span></li>
        </ul>
      </div>
      
    </div>
  </div>
</section>
