---
---
<section id="academics" class="py-24 bg-surface-container-highest">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="text-center mb-16">
      <span class="font-label-md text-label-md text-secondary uppercase tracking-[0.2em]">Academic Roadmap</span>
      <h2 class="font-headline-md text-headline-md text-primary mt-2">Stages of Mastery</h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border border-outline/20">
      <!-- Level 1: Muqaddimat -->
      <div class="bg-white p-12 border-b md:border-b-0 md:border-r border-outline/10">
        <div class="text-secondary font-headline-sm text-headline-sm mb-6">01. Muqaddimat</div>
        <h4 class="font-label-md text-label-md text-on-surface mb-4">THE FOUNDATION</h4>
        <ul class="space-y-4 font-body-md text-body-md text-on-surface-variant">
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary"></span>Arabic Grammar (Sarf/Nahw)</li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary"></span>Formal Logic (Mantiq)</li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary"></span>Introductory Jurisprudence</li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary"></span>Quranic Sciences</li>
        </ul>
      </div>
      
      <!-- Level 2: Sutuh -->
      <div class="bg-white p-12 border-b md:border-b-0 md:border-r border-outline/10 relative">
        <div class="absolute top-0 right-0 p-4">
          <span class="material-symbols-outlined text-secondary opacity-20 text-6xl">school</span>
        </div>
        <div class="text-secondary font-headline-sm text-headline-sm mb-6">02. Sutuh</div>
        <h4 class="font-label-md text-label-md text-on-surface mb-4">THE STRUCTURE</h4>
        <ul class="space-y-4 font-body-md text-body-md text-on-surface-variant">
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary"></span>Principles of Law (Usul)</li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary"></span>Comparative Philosophy</li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary"></span>Theology (Kalam)</li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary"></span>Advanced Rhetoric</li>
        </ul>
      </div>
      
      <!-- Level 3: Kharij -->
      <div class="bg-primary p-12 text-white">
        <div class="text-secondary-fixed font-headline-sm text-headline-sm mb-6">03. Kharij</div>
        <h4 class="font-label-md text-label-md text-white/70 mb-4">THE INDEPENDENT RESEARCH</h4>
        <ul class="space-y-4 font-body-md text-body-md text-white/90">
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary-fixed"></span>Ijtihad Foundations</li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary-fixed"></span>Expert Seminars</li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary-fixed"></span>Original Research</li>
          <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 bg-secondary-fixed"></span>Advanced Metaphysics</li>
        </ul>
      </div>
    </div>
  </div>
</section>
