<section class="py-24 bg-surface-container-low">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    
    <div class="text-center mb-16">
      <h2 class="font-display-lg text-display-lg-mobile md:text-headline-md text-primary mb-4" data-i18n="diff.title">The Babalridha Difference</h2>
      <div class="w-16 h-1 bg-secondary mx-auto"></div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Feature 1: Modern Pedagogy -->
      <div class="bg-white p-10 border border-outline/10 card-hover transition-all">
        <div class="mb-6">
          <span class="material-symbols-outlined text-4xl text-secondary">groups</span>
        </div>
        <h3 class="font-headline-sm text-headline-sm text-primary mb-4" data-i18n="diff.p1.title">Modern Pedagogy</h3>
        <p class="font-body-md text-body-md text-on-surface-variant" data-i18n="diff.p1.desc">
          We utilize modern cognitive science and structured assessment tools without compromising the depth of traditional texts.
        </p>
      </div>
      
      <!-- Feature 2: Global Perspective -->
      <div class="bg-white p-10 border border-outline/10 card-hover transition-all">
        <div class="mb-6">
          <span class="material-symbols-outlined text-4xl text-secondary">public</span>
        </div>
        <h3 class="font-headline-sm text-headline-sm text-primary mb-4" data-i18n="diff.p2.title">Global Perspective</h3>
        <p class="font-body-md text-body-md text-on-surface-variant" data-i18n="diff.p2.desc">
          Our students engage with contemporary sociological and philosophical challenges, preparing them to lead diverse communities.
        </p>
      </div>
      
      <!-- Feature 3: Focus on Adab -->
      <div class="bg-white p-10 border border-outline/10 card-hover transition-all">
        <div class="mb-6">
          <span class="material-symbols-outlined text-4xl text-secondary">menu_book</span>
        </div>
        <h3 class="font-headline-sm text-headline-sm text-primary mb-4" data-i18n="diff.p3.title">Focus on Adab</h3>
        <p class="font-body-md text-body-md text-on-surface-variant" data-i18n="diff.p3.desc">
          Academic excellence is viewed through the lens of spiritual cultivation, ensuring knowledge leads to humility and service.
        </p>
      </div>
      
    </div>
  </div>
</section>
