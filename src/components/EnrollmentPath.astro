---
---
<section id="apply" class="py-24 bg-background">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    
    <h2 class="font-headline-md text-headline-md text-center text-primary mb-16" data-i18n="apply.title">The Path to Enrollment</h2>
    
    <div class="flex flex-col md:flex-row justify-between items-start gap-12 relative">
      <!-- Connector Line -->
      <div class="hidden md:block absolute top-12 start-0 w-full h-[1px] bg-outline/20 -z-10"></div>
      
      <!-- Step 1 -->
      <div class="flex-1 text-center group w-full">
        <div class="w-24 h-24 bg-white border-2 border-secondary rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-secondary group-hover:text-white transition-all">
          <span class="material-symbols-outlined text-3xl">edit_note</span>
        </div>
        <h5 class="font-headline-sm text-headline-sm mb-2" data-i18n="apply.s1.title">Apply Online</h5>
        <p class="font-body-md text-body-md text-on-surface-variant" data-i18n="apply.s1.desc">Submit your academic records and personal statement.</p>
      </div>
      
      <!-- Step 2 -->
      <div class="flex-1 text-center group w-full">
        <div class="w-24 h-24 bg-white border-2 border-secondary rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-secondary group-hover:text-white transition-all">
          <span class="material-symbols-outlined text-3xl">rate_review</span>
        </div>
        <h5 class="font-headline-sm text-headline-sm mb-2" data-i18n="apply.s2.title">Review</h5>
        <p class="font-body-md text-body-md text-on-surface-variant" data-i18n="apply.s2.desc">Our academic board reviews your suitability and spirit.</p>
      </div>
      
      <!-- Step 3 -->
      <div class="flex-1 text-center group w-full">
        <div class="w-24 h-24 bg-white border-2 border-secondary rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-secondary group-hover:text-white transition-all">
          <span class="material-symbols-outlined text-3xl">video_chat</span>
        </div>
        <h5 class="font-headline-sm text-headline-sm mb-2" data-i18n="apply.s3.title">Interview</h5>
        <p class="font-body-md text-body-md text-on-surface-variant" data-i18n="apply.s3.desc">A personal dialogue with one of our lead instructors.</p>
      </div>
      
      <!-- Step 4 -->
      <div class="flex-1 text-center group w-full">
        <div class="w-24 h-24 bg-white border-2 border-secondary rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-secondary group-hover:text-white transition-all">
          <span class="material-symbols-outlined text-3xl">flight_takeoff</span>
        </div>
        <h5 class="font-headline-sm text-headline-sm mb-2" data-i18n="apply.s4.title">Visa & Travel</h5>
        <p class="font-body-md text-body-md text-on-surface-variant" data-i18n="apply.s4.desc">Complete logistical support for your move to Qom.</p>
      </div>
      
    </div>
  </div>
</section>
