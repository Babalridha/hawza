---
---
<section id="home" class="relative min-h-screen flex items-center pt-16 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-primary/40 z-10"></div>
    <div 
      class="w-full h-full bg-cover bg-center" 
      aria-label="A majestic traditional Islamic courtyard at dusk."
      style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCFM9adPJzhlLns8l1Pix02XN8irwpklwqjqCrUPgV2e4z3LXneVxU1GZLEl5GDS8eHaiSFIDvhNtN83ywE0L1urcnmHrQVqKCvYnw1VU_Y5HxxcYnXBaFx_YqEbIA2L53mRf2GNRFRVOboi4DKgR7dUMJ0A13Q6NjXkrdhWYivS-SIUEJQvkxo1SPE0nZBdNKpegtBPxQ9CbEfJ_twIJzPfL7xmyaPQkg9unebZ35ocmVPy_AZiQfI')"
    >
    </div>
  </div>
  
  <div class="relative z-20 w-full max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop text-white">
    <!-- Single Hero Container -->
    <div class="max-w-3xl">
      <p class="font-label-md text-label-md uppercase tracking-[0.2em] mb-4 text-secondary-fixed" data-i18n="hero.subtitle">Tradition • Rigor • Spirit</p>
      <h1 class="font-display-lg text-display-lg-mobile md:text-display-lg mb-8 leading-tight" data-i18n="hero.title">
        Sacred Knowledge for the <br /><span class="italic text-secondary-fixed">Modern World</span>
      </h1>
      <p class="font-body-lg text-body-lg mb-10 text-white/90 leading-relaxed max-w-2xl" data-i18n="hero.desc">
        Embark on a transformative journey through the classical Islamic sciences in the heart of Qom. We bridge centuries-old pedagogy with the intellectual challenges of the 21st century.
      </p>
      <div class="flex flex-col md:flex-row gap-4">
        <a href="#apply" class="inline-block text-center bg-secondary text-white font-label-md text-label-md px-10 py-5 hover:bg-on-secondary-fixed-variant transition-all border-b-2 border-secondary-fixed cursor-pointer" data-i18n="hero.apply">
          Apply Now
        </a>
        <a href="#academics" class="inline-block text-center bg-transparent border border-white/40 text-white font-label-md text-label-md px-10 py-5 hover:bg-white/10 transition-all cursor-pointer" data-i18n="hero.explore">
          Explore Curriculum
        </a>
      </div>
    </div>
  </div>
  
  <!-- Scroll Indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 animate-bounce">
    <span class="material-symbols-outlined text-white text-3xl">keyboard_double_arrow_down</span>
  </div>
</section>
