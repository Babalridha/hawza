---
<section class="py-24 bg-background overflow-hidden">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    
    <div class="mb-16">
      <h2 class="font-headline-md text-headline-md text-primary" data-i18n="life.title">Life in Qom</h2>
      <p class="font-body-md text-body-md text-on-surface-variant" data-i18n="life.subtitle">A sanctuary for the soul, a library for the mind.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-4 md:grid-rows-2 gap-4 h-[800px] md:h-[600px]">
      <!-- Large Feature: Holy Shrine -->
      <div class="md:col-span-2 md:row-span-2 relative group overflow-hidden">
        <div class="absolute inset-0 shrine-gradient z-10 opacity-60 group-hover:opacity-40 transition-opacity"></div>
        <img 
          class="w-full h-full object-cover" 
          data-i18n-alt="life.shrine.alt"
          alt="A breathtaking view of the golden dome of the Fatima Masumeh Shrine in Qom, Iran." 
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuBnrMSrz-fHj9SdKidwu3hxizQAEaSELMPnX-st_uWqCx6vQBfOsO-ejuSWsKv0LxO4vtiUsTGS2h6WonqdAzxWDv9Ek4MjNXlWj1zQKDelE_xlOrjIuYhES3pVdHA1j1XDPU15sYOan3UdK7DzFuqAEqp0ckUMntdreIja6UKilsMuUlP5DMqL10G709LTSfZAIuuEeEFp3UHjPC95eFdyrY-WmdKtEXko783xkpomndtyuF7PTvwH"
        />
        <div class="absolute bottom-0 left-0 right-0 p-8 z-20">
          <h4 class="text-white font-headline-sm text-headline-sm" data-i18n="life.shrine.title">The Holy Shrine</h4>
          <p class="text-white/80 font-body-md text-body-md" data-i18n="life.shrine.desc">A spiritual anchor for students from around the world.</p>
        </div>
      </div>
      
      <!-- Top Right: Grand Libraries -->
      <div class="md:col-span-2 relative group overflow-hidden">
        <div class="absolute inset-0 bg-primary/30 z-10"></div>
        <img 
          class="w-full h-full object-cover" 
          data-i18n-alt="life.library.alt"
          alt="A serene, high-ceilinged library with rows of ancient manuscripts." 
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuBwEBYONiJCYF5D8kZPcqwkw0g9q0gUyAFOB_LJAVMAMWZb_0XJH5-vBlvD5fLtXAJp96V5FkuLQoxYlR27aUTNRGqGozqkEFd7mcm0WbqrHSnqlZWVEKLjoulvvWwSIpL-KhXbRMyCszxtIv0c7iPdngDuY9ws-lY9hXmRstcDCmYJgCETLnRQZ1qI78NTR1e5SYK-lwLv8QzO9KJPbQ0AswLsYF5hzwFdKD6WzmKAdvAL0WkplWMX"
        />
        <div class="absolute inset-0 flex items-center justify-center z-20">
          <span class="text-white font-headline-sm text-headline-sm px-4 text-center" data-i18n="life.library.title">Grand Libraries</span>
        </div>
      </div>
      
      <!-- Bottom Right 1: Daily reflection / Persian Tea -->
      <div class="relative group overflow-hidden">
        <img 
          class="w-full h-full object-cover" 
          data-i18n-alt="life.tea.alt"
          alt="Persian tea near a book in a sunlit courtyard." 
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuAWXrUJ5W-Rn7RlhQNTuLpvyiECXy2L9Ud0yjHh15otKpOpVc0wJ2B7SoMHPM-0MfNOubEDo_RZmepwQmMKleOj8hc99IvvD1NNoAdB5BK-c5C3S5SrJ6oVZggBPEfcVchWMALlexFtA6iG4s6yNI0XsFmSsHwQXqvPxMYjnVTETFGqWfMW3QrwFB14akGjpvZxnykZE8Th0X_F4HqX0bwYX_wjmIV_l0sOqHmW0HyJJy0JfVhAHoyz"
        />
      </div>
      
      <!-- Bottom Right 2: Students in discussion -->
      <div class="relative group overflow-hidden">
        <img 
          class="w-full h-full object-cover" 
          data-i18n-alt="life.students.alt"
          alt="Two students in traditional scholarly robes walking in Qom." 
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuAVebM8LzHSz2OdIURohJD15Q0Get4DozRANcZBvw_0C7e79_mm19U1xth5lPf_2CH6RwqTaeid_GN3gEN7_HmX3nEhTZDSvW4FQI0gDn7pDdQ94SQ0bmPbfgyUeqf2Pn5qKpwe8uH7iZngXupqlzCSa3iYfwud4lcjqyIf7pI5uOFfYVE8UFFj58MJOFcwiiNzUQkEyE9WA1Aoyl3buf28IKnsS6AS07D8wOD0NSb9W3xF24VSeBgO"
        />
      </div>
    </div>
  </div>
</section>
